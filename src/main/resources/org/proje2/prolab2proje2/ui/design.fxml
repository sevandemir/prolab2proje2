<?xml version="1.0" encoding="UTF-8"?>

<!-- Main JavaFX UI layout design for the performance benchmarker application -->
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.text.Text?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="org.proje2.prolab2proje2.ui.MainController"
            styleClass="root">
    
    <!-- Top Header Title Section -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="header" spacing="20">
            <padding>
                <Insets left="20" right="20" top="10" bottom="10"/>
            </padding>
            <Text text="ML Performance Benchmarker" styleClass="title-text"/>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: #888888;"/>
        </HBox>
    </top>

    <!-- Sidebar Configuration Controls -->
    <left>
        <VBox spacing="20" styleClass="sidebar" prefWidth="250">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            
            <VBox spacing="10">
                <Label text="CONFIGURATION" styleClass="label-header"/>
                <Separator style="-fx-opacity: 0.2;"/>
            </VBox>

            <!-- Mode Selector: Single File or Split Files -->
            <VBox spacing="5">
                <Label text="Dataset Mode"/>
                <RadioButton fx:id="radioSingleFile" text="Single File" selected="true">
                    <toggleGroup><ToggleGroup fx:id="dataModeGroup"/></toggleGroup>
                </RadioButton>
                <RadioButton fx:id="radioSeparateFiles" text="Separate Train/Test Files" toggleGroup="$dataModeGroup"/>
            </VBox>

            <!-- Single File Mode Inputs -->
            <VBox fx:id="singleFileBox" spacing="5">
                <Label text="Dataset File"/>
                <HBox spacing="5">
                    <TextField fx:id="filePathField" editable="false" text="MarketSalesKocaeli.xlsx" HBox.hgrow="ALWAYS"/>
                    <Button text="..." onAction="#handleSelectFile"/>
                </HBox>
            </VBox>

            <!-- Separate File Mode Inputs -->
            <VBox fx:id="separateFilesBox" spacing="5" visible="false" managed="false">
                <VBox spacing="5">
                    <Label text="Training File"/>
                    <HBox spacing="5">
                        <TextField fx:id="trainPathField" editable="false" promptText="Select Train data..." HBox.hgrow="ALWAYS"/>
                        <Button text="..." onAction="#handleSelectTrainFile"/>
                    </HBox>
                </VBox>
                <VBox spacing="5">
                    <Label text="Testing File"/>
                    <HBox spacing="5">
                        <TextField fx:id="testPathField" editable="false" promptText="Select Test data..." HBox.hgrow="ALWAYS"/>
                        <Button text="..." onAction="#handleSelectTestFile"/>
                    </HBox>
                </VBox>
            </VBox>

            <VBox spacing="5">
                <Label text="K-Value (for KNN)"/>
                <TextField fx:id="kValueField" text="25" promptText="Enter K value..."/>
            </VBox>

            <VBox spacing="5">
                <Label text="Max Depth (for DT)"/>
                <TextField fx:id="maxDepthField" text="25" promptText="Enter Max Depth..."/>
            </VBox>

            <!-- Form Action Buttons -->
            <VBox spacing="5">
                <Label text="Actions"/>
                <Button text="Run Benchmarks" onAction="#handleStartTest" 
                        styleClass="button-primary" maxWidth="Infinity"/>
                <Button text="Clear All" onAction="#handleClearResults" 
                        maxWidth="Infinity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
            
            <VBox spacing="5" styleClass="card">
                <Label text="Last Run Avg. Accuracy" style="-fx-font-size: 10px;"/>
                <Label fx:id="avgAccuracyLabel" text="0.0%" styleClass="stat-value"/>
            </VBox>
        </VBox>
    </left>

    <!-- Center Analytical Workspace Tabs -->
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE">
            <tabs>
                <!-- Performance Metrics Dashboard Tab -->
                <Tab text="Dashboard">
                    <VBox spacing="20">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <HBox spacing="20" alignment="CENTER" VBox.vgrow="ALWAYS">
                            <BarChart fx:id="accuracyChart" title="Accuracy (%)" animated="true">
                                <xAxis><CategoryAxis label="Algorithm" /></xAxis>
                                <yAxis><NumberAxis label="Accuracy %" lowerBound="0" upperBound="100" autoRanging="false" /></yAxis>
                            </BarChart>
                            <BarChart fx:id="durationChart" title="Time (ms)" animated="true">
                                <xAxis><CategoryAxis label="Algorithm" /></xAxis>
                                <yAxis><NumberAxis label="Time (ms)" /></yAxis>
                            </BarChart>
                            <BarChart fx:id="memoryChart" title="Memory Used (MB)" animated="true">
                                <xAxis><CategoryAxis label="Algorithm" /></xAxis>
                                <yAxis><NumberAxis label="MB" /></yAxis>
                            </BarChart>
                        </HBox>
                    </VBox>
                </Tab>

                <!-- Individual Target Prediction Tab -->
                <Tab text="Individual Prediction">
                    <VBox spacing="10">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <Label text="Predict Category for User" styleClass="label-header"/>
                        
                        <GridPane hgap="15" vgap="15" styleClass="card">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            
                            <Label text="Gender:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                            <ComboBox fx:id="genderComboBox" prefWidth="150" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="E (Erkek)"/>
                                        <String fx:value="K (Kadın)"/>
                                    </FXCollections>
                                </items>
                                <value>
                                    <String fx:value="E (Erkek)"/>
                                </value>
                            </ComboBox>

                            <Label text="Spending Amount:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                            <TextField fx:id="spendingField" text="100.0" promptText="e.g. 250.5" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                            <Button text="Predict Now" onAction="#handleSinglePrediction" 
                                    styleClass="button-primary" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        </GridPane>

                        <HBox spacing="20">
                            <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                <Label text="KNN Prediction" style="-fx-font-weight: bold;"/>
                                <Label fx:id="knnResultLabel" text="N/A" styleClass="stat-value" style="-fx-text-fill: #3498db;"/>
                            </VBox>
                            <VBox spacing="10" styleClass="card" HBox.hgrow="ALWAYS">
                                <Label text="Decision Tree Prediction" style="-fx-font-weight: bold;"/>
                                <Label fx:id="dtResultLabel" text="N/A" styleClass="stat-value" style="-fx-text-fill: #e67e22;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                            <Label text="Tahmin Detayları ve Algoritma Yolları" styleClass="label-header"/>
                            <TextArea fx:id="predictionLogArea" editable="false" prefHeight="200" VBox.vgrow="ALWAYS"
                                      promptText="KNN komşuları ve Decision Tree dallanma yolları burada gösterilecektir..."/>
                        </VBox>
                    </VBox>
                </Tab>

                <!-- Detailed Execution Output and Matrix Tab -->
                <Tab text="System Logs &amp; Matrix">
                    <VBox spacing="10">
                        <padding>
                            <Insets top="20" right="20" bottom="20" left="20"/>
                        </padding>
                        <TextArea fx:id="logArea" VBox.vgrow="ALWAYS" editable="false" prefHeight="400"
                                  promptText="System output will appear here..."/>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>

</BorderPane>